{
  "name": "danegg",
  "version": "1.0.0",
  "description": "SvelteKit frontend with Express backend",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run frontend:dev\" \"bun run backend:dev\"",
    "frontend:dev": "cd frontend && bun run dev",
    "backend:dev": "cd backend && bun run dev",
    "build": "bun run frontend:build",
    "frontend:build": "cd frontend && bun run build",
    "start": "bun server.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "podman:build": "podman compose build",
    "podman:up": "podman compose up -d",
    "podman:down": "podman compose down",
    "podman:logs": "podman compose logs -f",
    "db:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:dev:down": "docker compose -f docker-compose.dev.yml down",
    "podman:db:dev:up": "podman compose -f docker-compose.dev.yml up -d",
    "podman:db:dev:down": "podman compose -f docker-compose.dev.yml down",
    "db:generate": "cd backend && bun run db:generate",
    "db:push": "cd backend && bun run db:push",
    "db:migrate": "cd backend && bun run db:migrate",
    "db:seed": "cd backend && bun run db:seed",
    "db:seed:themes": "cd backend && bun run db:seed:themes",
    "db:seed:themes:all": "cd backend && bun run db:seed:themes:all",
    "db:seed:themes:refresh": "cd backend && bun run db:seed:themes:refresh",
    "db:reset": "cd backend && bun run db:push && cd backend && bun run db:seed",
    "db:studio": "cd backend && bun run db:studio",
    "db:adminer": "echo '🌐 Adminer: http://localhost:8080'",
    "create:admin": "cd backend && bun run create:admin",
    "env:setup": "cp .env.example.dev .env && echo '✅ Created .env from .env.example.dev. For Docker prod: cp .env.example.prod .env'",
    "setup": "bun install && cd frontend && bun install && cd ../backend && bun install && bun run env:setup",
    "backend:typecheck": "cd backend && bun run typecheck",
    "backend:lint": "cd backend && bun run lint",
    "test": "bun run frontend:test && bun run backend:test",
    "frontend:test": "cd frontend && bun run test",
    "backend:test": "cd backend && bun run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:all": "PLAYWRIGHT_ALL_BROWSERS=1 playwright test",
    "test:e2e:webkit": "PLAYWRIGHT_ALL_BROWSERS=1 playwright test --project=webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.9",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0"
  }
}
