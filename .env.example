# Database
DATABASE_URL=postgresql://dane_gg:daneGGPassword!@localhost:5432/dane.gg

# Server
PORT=3000
HOST=0.0.0.0

# Backend API
BACKEND_PORT=3001

# Development
NODE_ENV=development

# Database Visualization
ADMINER_URL=http://localhost:8080

# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=dane.gg
VITE_APP_VERSION=2.0.0

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Site Configuration (fallbacks for database values)
DEFAULT_WEATHER_TYPE=none
DEFAULT_WEATHER_SPEED=1.0
ENFORCE_WEATHER_EFFECTS=false
SITE_TITLE=dane.gg - Software Engineer & Designer
SITE_DESCRIPTION=Hi, I'm Dane! I'm a software engineer & freelance designer from Manchester, UK.

# Last.fm API (for music widget)
VITE_LASTFM_API_KEY=your-lastfm-api-key
VITE_LASTFM_USERNAME=your-lastfm-username
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_USERNAME=your-lastfm-username

# Twitter/X API (for tweet widget)
# Get cookies by logging into Twitter/X in your browser, then copy all cookies
# Format: "cookie1=value1; cookie2=value2; cookie3=value3"
TWITTER_COOKIES=your-twitter-cookies-here
TWITTER_USERNAME=your-twitter-username-without-at
# Polling interval in milliseconds (default: 120000 = 2 minutes)
# Lower values = faster updates but more API calls
# Recommended: 60000 (1 min) to 300000 (5 min)
TWITTER_POLL_INTERVAL=120000

# Ntfy notifications (optional)
# Ntfy topic for receiving notifications (e.g., "dane-gg-alerts")
# Leave empty to disable notifications
NTFY_TOPIC=
# Custom Ntfy server URL (optional, defaults to https://ntfy.sh)
# NTFY_URL=https://ntfy.sh
