{
	"name": "backend",
	"version": "1.0.50",
	"type": "module",
	"imports": {
		"@repo/shared/*": "../shared/*"
	},
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun src/db/seed.ts",
		"db:seed:themes": "bun src/db/seeds/themes.ts",
		"db:seed:themes:all": "bun src/db/seeds/themes.ts --all",
		"db:seed:themes:refresh": "bun src/db/seeds/themes.ts --refresh",
		"db:reset": "bun run db:push && bun run db:seed",
		"db:migrate:display-order": "bun src/scripts/addDisplayOrderToCategories.ts",
		"create:admin": "bun src/scripts/createAdmin.ts",
		"db:merge-export": "bun src/scripts/mergeProductionExportData.ts"
	},
	"dependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/cookie-parser": "^1.4.9",
		"@types/express-session": "^1.18.2",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.0.0",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.15.5",
		"@types/uuid": "^11.0.0",
		"bcryptjs": "^3.0.2",
		"connect-pg-simple": "^10.0.0",
		"consola": "^3.4.2",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.2.2",
		"drizzle-orm": "0.36.4",
		"express": "^5.1.0",
		"express-rate-limit": "^8.1.0",
		"express-session": "^1.18.2",
		"express-slow-down": "^3.0.0",
		"jsonwebtoken": "^9.0.2",
		"multer": "^2.0.2",
		"node-cron": "^4.2.1",
		"otpauth": "^9.4.1",
		"postgres": "^3.4.7",
		"qrcode": "^1.5.4",
		"twitter-openapi-typescript": "^0.0.55",
		"uuid": "^13.0.0",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.22.0",
		"@types/cookie": "^0.6.0",
		"@types/cookie-signature": "^1.1.2",
		"@types/express": "^5.0.3",
		"@types/qrcode": "^1.5.5",
		"@types/ws": "^8.18.1",
		"bun-types": "latest",
		"drizzle-kit": "0.28.1",
		"eslint": "^9.22.0",
		"eslint-config-prettier": "^10.0.1",
		"globals": "^16.0.0",
		"prettier": "^3.4.2",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0"
	},
	"module": "src/index.js"
}
