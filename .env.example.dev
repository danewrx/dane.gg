# =============================================================================
# dane.gg — local development (repo root `.env`)
#
#   cp .env.example.dev .env
#
# Run Postgres: `bun run db:dev:up` (or `docker compose -f docker-compose.dev.yml up -d`)
# Docker production: copy `.env.example.prod` instead.
# =============================================================================

# Backend (required)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
JWT_SECRET=change-me-dev-jwt-secret
SESSION_SECRET=change-me-dev-session-secret

# Frontend
FRONTEND_PORT=3000
PUBLIC_ORIGIN=http://localhost:3000

# Backend/network
BACKEND_PORT=3001
HOST=0.0.0.0
COOKIE_SECURE=false
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Logging (optional; consola — backend uses LOG_LEVEL, browser bundle uses PUBLIC_LOG_LEVEL)
# LOG_LEVEL=info
# PUBLIC_LOG_LEVEL=info

# Integrations
LASTFM_API_KEY=lastfm_api_key
LASTFM_USERNAME=lastfm_username
TWITTER_COOKIES=twitter_cookies
TWITTER_USERNAME=twitter_username
#TWITTER_POLL_INTERVAL=120000 //DEPRECATED - USE TWITTER_FETCH_CRON INSTEAD
TWITTER_FETCH_CRON=*/2 * * * *
TWITTER_HEALTH_CHECK_CRON=0 */2 * * *
NTFY_TOPIC=dane.gg
NTFY_URL=https://ntfy.sh
UPTIME_KUMA_URL=https://kuma.example.com
UPTIME_KUMA_API_KEY=kuma_api_key

# Site config fallbacks (optional)
# DEFAULT_WEATHER_TYPE=none
# DEFAULT_WEATHER_SPEED=1.0
# ENFORCE_WEATHER_EFFECTS=false
# DEFAULT_WEB_NEKO_TYPE=white
# ENFORCED_WEB_NEKO_TYPE=white
# ENFORCE_WEB_NEKO=false
# SITE_TITLE=dane.gg - Software Engineer & Designer
# SITE_DESCRIPTION=Hi, I'm Dane! I'm a software engineer & freelance designer from Manchester, UK.

# Legacy aliases still supported by app/runtime:
# ORIGIN -> PUBLIC_ORIGIN
