{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "**/*.ts",
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "frontend/node_modules",
    "backend/node_modules",
    "frontend/build",
    "backend/build"
  ]
}
